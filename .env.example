# Single-relay (v0.1.x): use RELAY_AGENT_TOKEN
RELAY_AGENT_TOKEN=change_me_before_production

# Multi-relay (v0.2.x): use RELAY_INSTANCES instead of RELAY_AGENT_TOKEN
# RELAY_INSTANCES=[{"id":"public","token":"token-public","strfryConfig":"/etc/strfry-public.conf","strfryDb":"/var/lib/strfry-public/db"}]

STRFRY_BIN=strfry
STRFRY_DB_PATH=./strfry-db
WHITELIST_PATH=/etc/strfry/whitelist.txt
PORT=7800
# Optional: comma-separated extra CORS origins (defaults: relay-panel.bitmacro.io, localhost:3000)
# ALLOWED_ORIGINS=https://staging.example.com
